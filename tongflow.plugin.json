{
    "plugin": {
        "name": "SAM-Audio",
        "description": "Text-prompted sound separation with Meta SAM-Audio — denoise, isolate vocals, or extract any described sound.",
        "icon": "/plugins/tongflow-modal-sam-audio.svg"
    },
    "env": [
        {
            "key": "MODAL_TOKEN_ID",
            "required": true,
            "description": "Modal token id",
            "url": "https://modal.com/settings/tokens"
        },
        {
            "key": "MODAL_TOKEN_SECRET",
            "required": true,
            "description": "Modal token secret (paired with MODAL_TOKEN_ID)"
        },
        {
            "key": "HF_TOKEN",
            "required": true,
            "description": "Hugging Face token of an account granted access to facebook/sam-audio-large",
            "url": "https://huggingface.co/facebook/sam-audio-large"
        },
        {
            "key": "TONGFLOW_MODAL_CALL_TIMEOUT_S",
            "default": "2400",
            "description": "Max seconds to wait for a Modal call"
        }
    ]
}
